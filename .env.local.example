# ─────────────────────────────────────────────────────────────────────────────
# JNS Website — Firebase Configuration
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# Get all values from: Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id


# ─────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS (do this once)
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Go to https://console.firebase.google.com and create a project (or use existing)
#
# 2. Enable Firestore Database
#    → Build → Firestore Database → Create database → Start in production mode
#
# 3. Set Firestore Security Rules
#    → Firestore → Rules tab → paste the following:
#
#    rules_version = '2';
#    service cloud.firestore {
#      match /databases/{database}/documents {
#        // Anyone can submit a survey; only logged-in admins can read submissions
#        match /survey-submissions/{id} {
#          allow create: if true;
#          allow read, update, delete: if request.auth != null;
#        }
#        // Survey questions are public (needed for the form to load)
#        // Only admins can edit questions
#        match /survey-config/{id} {
#          allow read: if true;
#          allow write: if request.auth != null;
#        }
#      }
#    }
#
# 4. Enable Authentication → Email/Password sign-in
#    → Build → Authentication → Sign-in method → Email/Password → Enable
#
# 5. Create your admin account
#    → Authentication → Users → Add user
#    → Enter your email and a strong password
#    → This is what you use to log in at /admin
#
# 6. Register a Web App and copy config values into this file
#    → Project Settings (gear icon) → Your apps → Add app → Web
#    → Copy apiKey, authDomain, projectId, etc. into the fields above
#
# ─────────────────────────────────────────────────────────────────────────────
